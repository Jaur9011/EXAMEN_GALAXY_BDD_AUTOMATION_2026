<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<!-- Suite completa de regresion: ejecuta las 6 historias de usuario -->
<suite name="JuiceShop Regression Suite" parallel="methods" thread-count="3" data-provider-thread-count="3">

    <listeners>
        <listener class-name="com.juice.listeners.ScreenshotListener"/>
    </listeners>

    <test name="Regression - Todas las historias">
        <classes>
            <class name="com.juice.tests.TestRunner"/>
        </classes>
    </test>

</suite>
